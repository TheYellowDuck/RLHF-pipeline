# Copy this file to `.env` and fill in your keys. `.env` is gitignored — it never gets committed.
# The scripts auto-load `.env` (no extra packages needed).

# Anthropic key — only needed for the independent LLM-as-judge eval:
#   python scripts/evaluate.py judge --policy checkpoints/ppo --base Qwen/Qwen2.5-0.5B-Instruct
ANTHROPIC_API_KEY=

# Optional: HuggingFace token, only if you pull a gated model/dataset.
# HF_TOKEN=
